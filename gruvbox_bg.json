{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "bg0": "#282828",
    "bg1": "#3c3836",
    "bg2": "#504945",
    "fg0": "#fbf1c7",
    "orange": "#fe8019",
    "dark_orange": "#d65d0e",
    "brown": "#a89984",
    "dark_brown": "#7c6f64",
    "red": "#fb4934",
    "yellow": "#fabd2f"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "foreground": "p:bg0",
          "background": "p:orange",
          "leading_diamond": "",
          "template": "👤 {{ .UserName }} ",
          "style": "diamond",
          "type": "session"
        },
        {
          "background": "p:dark_brown",
          "foreground": "p:fg0",
          "template": " 📂 {{ .Path }} ",
          "properties": {
            "style": "folder"
          },
          "style": "diamond",
          "type": "path"
        },
        {
          "properties": {
            "fetch_status": true
          },
          "template": "  {{ .HEAD }} ",
          "background": "p:bg2",
          "foreground": "p:orange",
          "type": "git",
          "style": "diamond"
        },
        {
          "type": "command",
          "style": "diamond",
          "background": "p:bg1",
          "foreground": "p:orange",
          "properties": {
            "command": "/home/rogissart/Documents/Code/applet/bg_prompt.py",
            "cache_duration": "5s"
          },
          "template": " 🩸 {{ .Output }} ",
          "foreground_templates": [
            "{{ if or (le (.Output | strtol) 75) (ge (.Output | strtol) 250) }}p:red{{ end }}",
            "{{ if or (le (.Output | strtol) 90) (ge (.Output | strtol) 180) }}p:yellow{{ end }}"
          ]
        },
        {
          "type": "time",
          "style": "diamond",
          "background": "p:bg1",
          "foreground": "p:brown",
          "trailing_diamond": "",
          "template": " 🕒 {{.CurrentDate | date \"15:04\"}} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "\n ",
          "foreground": "p:orange",
          "type": "text",
          "style": "plain"
        }
      ],
      "newline": false
    }
  ],
  "version": 3,
  "final_space": true
}
